{
  "AlertBannerBase": [
    {
      "attribute": "open",
      "property": "open",
      "type": "boolean",
      "default": "false",
      "description": "Controls the display of the alert banner."
    },
    {
      "attribute": "dismissible",
      "property": "dismissible",
      "type": "boolean",
      "default": "false",
      "description": "Whether to include an icon-only close button to dismiss the alert banner."
    },
    {
      "attribute": "variant",
      "property": "variant",
      "type": "AlertBannerVariant",
      "description": "The variant applies specific styling when set to `negative` or `info`;\n`variant` attribute is removed when it's passed an invalid variant."
    }
  ],
  "AlertDialog": [
    {
      "attribute": "variant",
      "property": "variant",
      "type": "AlertDialogVariants"
    }
  ],
  "AssetBase": [
    {
      "attribute": "variant",
      "property": "variant",
      "type": "AssetVariant | undefined",
      "description": "The variant of the asset. When not provided, slot content is rendered (e.g., an image)."
    },
    {
      "attribute": "label",
      "property": "label",
      "type": "string",
      "default": "''",
      "description": "Accessible label for the asset’s file or folder variant."
    }
  ],
  "BadgeBase": [
    {
      "attribute": "size",
      "type": "ElementSize",
      "description": "The size of the badge."
    },
    {
      "attribute": "fixed",
      "property": "fixed",
      "type": "FixedValues | undefined",
      "description": "The fixed position of the badge."
    }
  ],
  "ButtonBase": [
    {
      "attribute": "active",
      "property": "active",
      "type": "boolean",
      "default": "false"
    },
    {
      "attribute": "type",
      "property": "type",
      "type": "'button' | 'submit' | 'reset'",
      "default": "'button'",
      "description": "The default behavior of the button.\nPossible values are: `button` (default), `submit`, and `reset`."
    }
  ],
  "CheckboxMixin": [
    {
      "attribute": "checked",
      "property": "checked",
      "type": "boolean",
      "default": "false"
    },
    {
      "attribute": "name",
      "property": "name",
      "type": "string | undefined"
    },
    {
      "attribute": "readonly",
      "property": "readonly",
      "type": "boolean",
      "default": "false"
    }
  ],
  "DialogBase": [
    {
      "attribute": "dismissable",
      "property": "dismissable",
      "type": "boolean",
      "default": "false"
    },
    {
      "attribute": "open",
      "property": "open",
      "type": "boolean",
      "default": "false"
    },
    {
      "attribute": "mode",
      "property": "mode",
      "type": "'fullscreen' | 'fullscreenTakeover' | undefined"
    },
    {
      "attribute": "responsive",
      "property": "responsive",
      "type": "boolean",
      "default": "false",
      "description": "When set to true, fills screens smaller than 350px high and 400px wide with the full dialog."
    },
    {
      "attribute": "underlay",
      "property": "underlay",
      "type": "boolean",
      "default": "false"
    }
  ],
  "DividerBase": [
    {
      "attribute": "size",
      "type": "ElementSize",
      "description": "The size of the divider."
    },
    {
      "attribute": "vertical",
      "property": "vertical",
      "type": "boolean",
      "default": "false",
      "description": "Whether the divider is vertical. If false, the divider is horizontal. The default is false."
    },
    {
      "attribute": "static-color",
      "property": "staticColor",
      "type": "DividerStaticColor | undefined",
      "description": "The static color variant to use for the divider."
    }
  ],
  "ExpandableElement": [
    {
      "attribute": "placement",
      "property": "placement",
      "type": "\"top\" | \"top-start\" | \"top-end\" | \"right\" | \"right-start\" | \"right-end\" | \"bottom\" | \"bottom-start\" | \"bottom-end\" | \"left\" | \"left-start\" | \"left-end\"",
      "default": "'bottom-start'",
      "description": "The preferred placement of the component's overlay relative to the trigger button."
    },
    {
      "attribute": "disabled",
      "property": "disabled",
      "type": "boolean",
      "default": "false",
      "description": "Whether the component is disabled. When disabled, the component cannot be interacted with."
    },
    {
      "attribute": "focused",
      "property": "focused",
      "type": "boolean",
      "default": "false",
      "description": "Whether the component currently has visible focus."
    },
    {
      "attribute": "readonly",
      "property": "readonly",
      "type": "boolean",
      "default": "false",
      "description": "Whether the component is read-only. When read-only, the component displays its value but cannot be changed."
    },
    {
      "attribute": "pending",
      "property": "pending",
      "type": "boolean",
      "default": "false",
      "description": "Whether the items are currently loading."
    },
    {
      "attribute": "force-popover",
      "property": "forcePopover",
      "type": "boolean",
      "default": "false",
      "description": "Forces the component to render as a popover on mobile instead of a tray."
    },
    {
      "attribute": "open",
      "property": "open",
      "type": "boolean",
      "default": "false",
      "description": "Whether the component's menu overlay is currently open."
    }
  ],
  "FieldGroup": [
    {
      "attribute": "horizontal",
      "property": "horizontal",
      "type": "boolean",
      "default": "false"
    },
    {
      "attribute": "invalid",
      "property": "invalid",
      "type": "boolean",
      "default": "false"
    },
    {
      "attribute": "label",
      "property": "label",
      "type": "string",
      "default": "''"
    },
    {
      "attribute": "vertical",
      "property": "vertical",
      "type": "boolean",
      "default": "false"
    }
  ],
  "Focusable": [
    {
      "attribute": "disabled",
      "property": "disabled",
      "type": "boolean",
      "default": "false",
      "description": "Disable this control. It will not receive focus or events"
    },
    {
      "attribute": "autofocus",
      "property": "autofocus",
      "type": "boolean",
      "default": "false",
      "description": "When this control is rendered, focus it automatically"
    },
    {
      "attribute": "tabIndex",
      "property": "tabIndex",
      "type": "number",
      "description": "The tab index to apply to this control. See general documentation about\nthe tabindex HTML property"
    }
  ],
  "IconBase": [
    {
      "attribute": "label",
      "property": "label",
      "type": "string",
      "default": "''"
    },
    {
      "attribute": "size",
      "property": "size",
      "type": "'xxs' | 'xs' | 's' | 'm' | 'l' | 'xl' | 'xxl' | undefined"
    }
  ],
  "LikeAnchor": [
    {
      "attribute": "download",
      "property": "download",
      "type": "string | undefined",
      "description": "Causes the browser to treat the linked URL as a download."
    },
    {
      "attribute": "label",
      "property": "label",
      "type": "string | undefined",
      "description": "An accessible label that describes the component.\nIt will be applied to aria-label, but not visually rendered."
    },
    {
      "attribute": "href",
      "property": "href",
      "type": "string | undefined",
      "description": "The URL that the hyperlink points to."
    },
    {
      "attribute": "target",
      "property": "target",
      "type": "'_blank' | '_parent' | '_self' | '_top' | undefined",
      "description": "Where to display the linked URL, as the name for a browsing context (a tab, window, or &lt;iframe&gt;)."
    },
    {
      "attribute": "referrerpolicy",
      "property": "referrerpolicy",
      "type": "| 'no-referrer'\n      | 'no-referrer-when-downgrade'\n      | 'origin'\n      | 'origin-when-cross-origin'\n      | 'same-origin'\n      | 'strict-origin'\n      | 'strict-origin-when-cross-origin'\n      | 'unsafe-url' | undefined",
      "description": "How much of the referrer to send when following the link."
    },
    {
      "attribute": "rel",
      "property": "rel",
      "type": "string | undefined",
      "description": "The relationship of the linked URL as space-separated link types."
    }
  ],
  "Menu": [
    {
      "attribute": "selects",
      "property": "selects",
      "type": "undefined | 'inherit' | 'single' | 'multiple'",
      "description": "how the menu allows selection of its items:\n- `undefined` (default): no selection is allowed\n- `\"inherit\"`: the selection behavior is managed from an ancestor\n- `\"single\"`: only one item can be selected at a time\n - `\"multiple\"`: multiple items can be selected"
    },
    {
      "attribute": "label",
      "property": "label",
      "type": "string",
      "default": "''",
      "description": "label of the menu"
    },
    {
      "attribute": "ignore",
      "property": "ignore",
      "type": "boolean",
      "default": "false",
      "description": "whether menu should be ignored by roving tabindex controller"
    },
    {
      "attribute": "value",
      "property": "value",
      "type": "string",
      "default": "''",
      "description": "value of the selected item(s)"
    },
    {
      "attribute": "value-separator",
      "property": "valueSeparator",
      "type": "string",
      "default": "','"
    }
  ],
  "Popover": [
    {
      "attribute": "placement",
      "property": "placement",
      "type": "\"top\" | \"top-start\" | \"top-end\" | \"right\" | \"right-start\" | \"right-end\" | \"bottom\" | \"bottom-start\" | \"bottom-end\" | \"left\" | \"left-start\" | \"left-end\""
    },
    {
      "attribute": "open",
      "property": "open",
      "type": "boolean",
      "default": "false",
      "description": "Whether the popover is visible or not."
    },
    {
      "attribute": "tip",
      "property": "tip",
      "type": "boolean",
      "default": "false"
    }
  ],
  "ProgressCircleBase": [
    {
      "attribute": "size",
      "type": "ElementSize",
      "description": "The size of the progress circle."
    },
    {
      "attribute": "indeterminate",
      "property": "indeterminate",
      "type": "boolean",
      "default": "false",
      "description": "Whether the progress circle shows indeterminate progress (loading state).\n\nWhen true, displays an animated loading indicator instead of a specific progress value."
    },
    {
      "attribute": "label",
      "property": "label",
      "type": "string",
      "default": "''",
      "description": "Accessible label for the progress circle.\n\nUsed to provide context about what is loading or progressing."
    },
    {
      "attribute": "progress",
      "property": "progress",
      "type": "number",
      "default": "0",
      "description": "Progress value from 0 to 100.\n\nOnly relevant when indeterminate is false."
    }
  ],
  "SliderHandle": [
    {
      "attribute": "value",
      "property": "value",
      "type": "number",
      "description": "By default, the value of a Slider Handle will be halfway between its\n`min` and `max` values, or the `min` value when `max` is less than `min`."
    },
    {
      "attribute": "default-value",
      "property": "defaultValue",
      "type": "number",
      "description": "Set the default value of the handle. Setting this property will cause the\nhandle to reset to the default value on double click or pressing the `escape` key."
    },
    {
      "attribute": "dragging",
      "property": "dragging",
      "type": "boolean",
      "default": "false"
    },
    {
      "attribute": "highlight",
      "property": "highlight",
      "type": "boolean",
      "default": "false"
    },
    {
      "attribute": "name",
      "property": "name",
      "type": "string",
      "default": "''"
    },
    {
      "attribute": "min",
      "property": "min",
      "type": "number | 'previous' | undefined"
    },
    {
      "attribute": "max",
      "property": "max",
      "type": "number | 'next' | undefined"
    },
    {
      "attribute": "step",
      "property": "step",
      "type": "number | undefined"
    },
    {
      "attribute": "format-options",
      "property": "formatOptions",
      "type": "NumberFormatOptions | undefined"
    },
    {
      "attribute": "label",
      "property": "label",
      "type": "string",
      "default": "''"
    }
  ],
  "StatusLightBase": [
    {
      "attribute": "size",
      "type": "ElementSize",
      "description": "The size of the status light."
    }
  ],
  "TextfieldBase": [
    {
      "attribute": "allowed-keys",
      "property": "allowedKeys",
      "type": "string",
      "default": "''",
      "description": "A regular expression outlining the keys that will be allowed to update the value of the form control."
    },
    {
      "attribute": "focused",
      "property": "focused",
      "type": "boolean",
      "default": "false"
    },
    {
      "attribute": "invalid",
      "property": "invalid",
      "type": "boolean",
      "default": "false",
      "description": "Whether the `value` held by the form control is invalid."
    },
    {
      "attribute": "label",
      "property": "label",
      "type": "string",
      "default": "''",
      "description": "A string applied via `aria-label` to the form control when a user visible label is not provided."
    },
    {
      "attribute": "name",
      "property": "name",
      "type": "string | undefined",
      "description": "Name of the form control."
    },
    {
      "attribute": "placeholder",
      "property": "placeholder",
      "type": "string",
      "default": "''",
      "description": "Text that appears in the form control when it has no value set"
    },
    {
      "attribute": "type",
      "property": "_type",
      "type": "TextfieldType",
      "default": "'text'"
    },
    {
      "attribute": "pattern",
      "property": "pattern",
      "type": "string | undefined",
      "description": "Pattern the `value` must match to be valid"
    },
    {
      "attribute": "grows",
      "property": "grows",
      "type": "boolean",
      "default": "false",
      "description": "Whether a form control delivered with the `multiline` attribute will change size\nvertically to accomodate longer input"
    },
    {
      "attribute": "maxlength",
      "property": "maxlength",
      "type": "number",
      "default": "-1",
      "description": "Defines the maximum string length that the user can enter"
    },
    {
      "attribute": "minlength",
      "property": "minlength",
      "type": "number",
      "default": "-1",
      "description": "Defines the minimum string length that the user can enter"
    },
    {
      "attribute": "multiline",
      "property": "multiline",
      "type": "boolean",
      "default": "false",
      "description": "Whether the form control should accept a value longer than one line"
    },
    {
      "attribute": "readonly",
      "property": "readonly",
      "type": "boolean",
      "default": "false",
      "description": "Whether a user can interact with the value of the form control"
    },
    {
      "attribute": "tooltip-placement",
      "property": "truncatedValueTooltipPlacement",
      "type": "Placement",
      "default": "'bottom'",
      "description": "Placement of the tooltip shown when the value is truncated (e.g. 'bottom', 'top').\nDefaults to 'bottom' per Spectrum design."
    },
    {
      "attribute": "rows",
      "property": "rows",
      "type": "number",
      "default": "-1",
      "description": "The specific number of rows the form control should provide in the user interface"
    },
    {
      "attribute": "valid",
      "property": "valid",
      "type": "boolean",
      "default": "false",
      "description": "Whether the `value` held by the form control is valid."
    },
    {
      "attribute": "value",
      "property": "value",
      "type": "string | number",
      "description": "The value held by the form control"
    },
    {
      "attribute": "quiet",
      "property": "quiet",
      "type": "boolean",
      "default": "false",
      "description": "Whether to display the form control with no visible background"
    },
    {
      "attribute": "required",
      "property": "required",
      "type": "boolean",
      "default": "false",
      "description": "Whether the form control will be found to be invalid when it holds no `value`"
    },
    {
      "attribute": "autocomplete",
      "property": "autocomplete",
      "type": "| 'list'\n    | 'none'\n    | HTMLInputElement['autocomplete']\n    | HTMLTextAreaElement['autocomplete'] | undefined",
      "description": "What form of assistance should be provided when attempting to supply a value to the form control\n\nNote: combobox overrides `autocomplete` intentionally with `aria-autocomplete` values, which is\nwhy those values (although invalid for native `autocomplete`) are included here to support the\ncombobox accessibility pattern."
    }
  ]
}
